# ══════════════════════════════════════
#  LaborAr — Variables de entorno
#  Copiá este archivo como .env y completá los valores
# ══════════════════════════════════════

# ── SERVIDOR ──
PORT=3002
NODE_ENV=production

# ── JWT ──
# Generá con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CAMBIA_ESTO_POR_UN_STRING_LARGO_Y_ALEATORIO
JWT_REFRESH_SECRET=CAMBIA_ESTO_POR_OTRO_STRING_LARGO_Y_ALEATORIO

# ── BASE DE DATOS ──
DB_PATH=./laborar.db

# ── EMAIL (para recuperar contraseña) ──
# Opción 1: Gmail con App Password (recomendado)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu-email@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx   # App Password de Gmail, no tu contraseña normal
SMTP_FROM="LaborAr <no-reply@laborar.com>"

# ── GOOGLE OAUTH ──
# Crear en: https://console.cloud.google.com → APIs → Credentials → OAuth 2.0
GOOGLE_CLIENT_ID=TU_GOOGLE_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=TU_GOOGLE_CLIENT_SECRET
GOOGLE_REDIRECT_URI=http://TU_IP:3002/auth/google/callback

# ── URL DEL FRONTEND ──
# La IP o dominio donde está hosteado index.html
FRONTEND_URL=http://TU_IP

# ── GROQ (para el agente IA) ──
GROQ_API_KEY=gsk_TU_CLAVE_GROQ
